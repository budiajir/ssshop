{
  "version": 2,
  "builds": [
    {
      "src": "src/index.ts",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "src/index.ts"
    },
    {
      "src": "/admin.html",
      "dest": "public/admin.html"
    },
    {
      "src": "/admin.js",
      "dest": "public/admin.js"
    },
    {
      "src": "/app.js",
      "dest": "public/app.js"
    },
    {
      "src": "/style.css",
      "dest": "public/style.css"
    },
    {
      "src": "/qris.png",
      "dest": "public/qris.png"
    },
    {
      "src": "/(.*)",
      "dest": "public/index.html"
    }
  ]
}
